# Sample environment for the ds_2026 stack.
# Copy to .env and fill in real values:  cp .env.example .env
# (.env is gitignored; .env.example is committed as the template.)

# Docker Hub username for image tags/push. Leave blank to build & deploy
# locally (images tagged local/ds-*). Set it (and run `docker login`) to push.
DOCKERHUB_USERNAME=

# Telegram alerts (disabled by default so the stack runs without credentials).
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_TELEGRAM_ATTACH_IMAGE=true

# Webhook (optional)
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=
